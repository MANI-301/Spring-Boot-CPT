package com.app;

import org.springframework.web.bind.annotation.DeleteMapping;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.PutMapping;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RequestParam;
import org.springframework.web.bind.annotation.RestController;

import com.app.model.response.UserRest;

@RestController
@RequestMapping("/users")
public class UserRestController {

    // URL: http://localhost:8080/users/111
    @GetMapping(path = "/{userId}")
    public String getUserById(@PathVariable String userId) {
        return "User ID: " + userId;
    }
  
    // URL: http://localhost:8081/users?page=12&limit=10
    @GetMapping
    public String getUsersWithParams(
            @RequestParam(value = "page", defaultValue = "11") int page,
            @RequestParam(required = false) String limit) {
        return "Get users was called with page: " + page + " Limit: " + limit;
    }
  
    // URL: http://localhost:8080/users/user/111
    @GetMapping(path = "/user/{userId}")
    public UserRest getUserObject(@PathVariable String userId) {
        UserRest returnValue = new UserRest();
        returnValue.setFirstName("Rahul");
        returnValue.setLastName("Pawar");
        returnValue.setEmail("rahul@gmail.com");
        returnValue.setUserId(userId);
        return returnValue;
    }

    // URL: http://localhost:8080/users/getUser
    @GetMapping("/getUser")
    public String getUserInfo() {
        return "Get user was called ";
    }
	
    // URL: http://localhost:8080/users
    @PostMapping
    public String postUser() {
        return "Post user was called ";
    }
	
    // URL: http://localhost:8080/users
    @PutMapping
    public String putUser() {
        return "Put user was called ";
    }
	
    // URL: http://localhost:8080/users
    @DeleteMapping
    public String deleteUser() {
        return "Delete user was called ";
    }
}
